# =============================================================================
# NEXA OPER — Web (Next.js)
# =============================================================================
#
# Em produção o PM2 lê como:
#   /var/www/nexa-oper/apps/web/.env.local
#
# Como preparar:
#   cp apps/web/.env.example apps/web/.env.local
#
# O ecosystem.config.js também injeta em runtime:
#   - NODE_ENV=production
#   - NEXTAUTH_URL (URL pública do dashboard)
#   - NEXT_PUBLIC_API_URL (URL pública da API)
#   - NEXT_PUBLIC_PHOTOS_BASE_URL / NEXT_PUBLIC_UPLOAD_BASE_URL
#   - UPLOAD_PROXY_TARGET
#
# Documentação completa: /.env.example na raiz do monorepo
#
# =============================================================================


# --- Banco (server actions e Prisma no dashboard) ---

DATABASE_URL="mysql://usuario:senha@localhost:3306/nexa_oper"


# --- Autenticação (NextAuth) ---

# URL pública do dashboard — SEM barra no final
NEXTAUTH_URL=https://nexa.xsys.team

# Secret exclusivo do NextAuth (diferente do JWT_SECRET da API)
NEXTAUTH_SECRET="troque-por-outro-secret-longo-e-aleatorio"


# --- URLs públicas (browser + server) ---

# URL pública da API — obrigatória em produção
NEXT_PUBLIC_API_URL=https://api.nexa.xsys.team

# Base para exibir fotos no dashboard
NEXT_PUBLIC_PHOTOS_BASE_URL=https://api.nexa.xsys.team/uploads

# Base explícita de uploads/CDN (tem prioridade)
NEXT_PUBLIC_UPLOAD_BASE_URL=https://api.nexa.xsys.team/uploads


# --- Uploads (server-side do Next) ---

# Mesma pasta usada pela API em produção
UPLOAD_ROOT=/var/www/apps/nexa-oper/uploads

# Proxy interno do Next para /uploads/* → API
UPLOAD_PROXY_TARGET=https://api.nexa.xsys.team


# --- Logs ---

LOG_PATH=/var/www/apps/nexa-oper/logs


# --- Opcional ---

# Envio de erros do browser para a API
# NEXT_PUBLIC_API_LOG_URL=https://api.seudominio.com

# Debug NextAuth (somente dev)
# NEXTAUTH_DEBUG=true
