# =============================================================================
# NEXA OPER — API (NestJS)
# =============================================================================
#
# Em produção o PM2 lê ESTE arquivo:
#   /var/www/nexa-oper/apps/api/.env
#
# Como preparar:
#   cp apps/api/.env.example apps/api/.env
#
# O ecosystem.config.js também injeta alguns valores em runtime:
#   - NODE_ENV=production
#   - PORT=3001
#   - LOG_PATH=/var/www/nexa-oper/logs
#   - TRUST_PROXY=true
#   - UPLOAD_BASE_URL / UPLOAD_PROXY_TARGET (derivados de MONOREPO_BASE_URL)
#
# Documentação completa de todas as variáveis: /.env.example na raiz do monorepo
#
# =============================================================================


# --- Obrigatórias ---

DATABASE_URL="mysql://usuario:senha@localhost:3306/nexa_oper"
JWT_SECRET="troque-por-um-secret-com-32-ou-mais-caracteres-aleatorios"


# --- Servidor ---

NODE_ENV=production
PORT=3001
GLOBAL_PREFIX=api
TZ=America/Sao_Paulo

# URL pública do dashboard — obrigatório para CORS em produção
CORS_ORIGINS="https://nexa.xsys.team"

# Atrás de Nginx: true
TRUST_PROXY=true

# Site com HTTPS: true (habilita HSTS)
HAS_HTTPS=true


# --- Uploads ---

UPLOAD_STORAGE=local
UPLOAD_ROOT=/var/www/apps/nexa-oper/uploads
UPLOAD_MAX_FILE_SIZE_BYTES=10485760

# A API retorna URLs absolutas com esta base
UPLOAD_BASE_URL=https://api.nexa.xsys.team/uploads

# Fallback para arquivos antigos em outro disco/pasta
# UPLOAD_LEGACY_ROOTS=


# --- Upload mobile (atividades com fotos inline) ---

ATIVIDADE_UPLOAD_JSON_LIMIT=12mb
ATIVIDADE_UPLOAD_TX_TIMEOUT_MS=60000


# --- Jobs ---

# Fila de checklists na abertura de turno
TURNO_CHECKLIST_SYNC_ENABLED=true
TURNO_CHECKLIST_SYNC_CRON=*/1 * * * *
TURNO_CHECKLIST_SYNC_LOCK_TTL_MS=120000

# Reconciliação de fotos de checklist (ligar se necessário)
CHECKLIST_PHOTO_RECONCILE_ENABLED=false

# Reconciliação escala vs turnos (opcional)
# TURNO_RECONCILE_ENABLED=false


# --- Logs ---

LOG_LEVEL=info
LOG_PRETTY=false
SERVICE_NAME=nexa-api


# --- Versão mínima do app mobile (opcional) ---
# MOBILE_MIN_VERSION_ANDROID=1.8.0
# MOBILE_MIN_VERSION_ANDROID_LOGIN=1.8.0
# MOBILE_MIN_VERSION_ANDROID_OPEN_TURNO=1.8.0


# --- S3 (quando UPLOAD_STORAGE=s3) ---
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_ENDPOINT=
# AWS_S3_PUBLIC_URL=
