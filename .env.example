# =============================================================================
# NEXA OPER — Variáveis de ambiente (monorepo)
# =============================================================================
#
# Uso local (recomendado para dev):
#   cp .env.example .env
#   # edite os valores e rode: npm run dev
#
# Uso em produção (PM2):
#   - API  → apps/api/.env        (ver apps/api/.env.example)
#   - Web  → apps/web/.env.local  (ver apps/web/.env.example)
#   - DB   → packages/db/.env     (opcional; scripts Prisma)
#
# Prioridade de leitura (API e Web):
#   1. apps/<app>/.env.local
#   2. apps/<app>/.env
#   3. .env.local (raiz)
#   4. .env (raiz)
#
# Checklist antes do deploy:
#   [ ] DATABASE_URL apontando para o banco de produção
#   [ ] npm run db:migrate:deploy executado com sucesso
#   [ ] JWT_SECRET com 32+ caracteres (diferente do dev)
#   [ ] NEXTAUTH_SECRET diferente do JWT_SECRET
#   [ ] CORS_ORIGINS com a URL pública do dashboard
#   [ ] NEXTAUTH_URL e NEXT_PUBLIC_* com URLs públicas corretas
#   [ ] UPLOAD_ROOT em caminho absoluto persistente (ex.: /var/www/nexa-oper/uploads)
#   [ ] TRUST_PROXY=true atrás de Nginx/reverse proxy
#   [ ] HAS_HTTPS=true quando o site usa HTTPS de ponta a ponta
#
# =============================================================================


# -----------------------------------------------------------------------------
# Geral
# -----------------------------------------------------------------------------

# development | production | test
NODE_ENV=development

# Timezone IANA usada por Date, Prisma e logs
TZ=America/Sao_Paulo


# -----------------------------------------------------------------------------
# Banco de dados (API + Web server actions + Prisma)
# -----------------------------------------------------------------------------

# MySQL — obrigatório em todos os ambientes
DATABASE_URL="mysql://usuario:senha@localhost:3306/nexa_oper"

# Usado apenas em `prisma migrate dev` (não necessário em produção)
# SHADOW_DATABASE_URL="mysql://usuario:senha@localhost:3306/nexa_oper_shadow"

# Opcional: força timezone da sessão MySQL (ex.: -03:00, UTC)
# DATABASE_TIME_ZONE=-03:00


# -----------------------------------------------------------------------------
# API NestJS
# -----------------------------------------------------------------------------

PORT=3001
GLOBAL_PREFIX=api

# Obrigatório — mínimo 32 caracteres
JWT_SECRET="troque-por-um-secret-com-32-ou-mais-caracteres-aleatorios"

# Origens permitidas no CORS (CSV ou JSON array)
# Em produção: liste SOMENTE o domínio do dashboard
# Ex.: CORS_ORIGINS=https://oper.seudominio.com
CORS_ORIGINS="http://localhost:3000"

# Atrás de Nginx/reverse proxy — necessário para IP real e cookies
TRUST_PROXY=false

# Em produção com HTTPS: habilita HSTS no Helmet
HAS_HTTPS=false

# Limites de body HTTP
JSON_LIMIT=2mb
URLENCODED_LIMIT=2mb
REQUEST_TIMEOUT_MS=60000

# Upload de atividades mobile (JSON grande com fotos em base64)
ATIVIDADE_UPLOAD_JSON_LIMIT=12mb
# Timeout da transação Prisma ao persistir medidor/materiais/APR (ms)
ATIVIDADE_UPLOAD_TX_TIMEOUT_MS=60000

# Swagger — só aparece fora de produção
SWAGGER_ENABLED=true

# Helmet (deixe false se Swagger quebrar)
SECURITY_CSP=false
SECURITY_COEP=false

# Rate limit — reservado para uso futuro
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PER_IP=20
RATE_LIMIT_MAX_PER_USER=5


# -----------------------------------------------------------------------------
# Logs da API (Pino)
# -----------------------------------------------------------------------------

LOG_LEVEL=info
LOG_PRETTY=true
SERVICE_NAME=nexa-api
LOG_PATH=./logs

# Gravar também em arquivo (útil fora do PM2)
# LOG_TO_FILE=true
# LOG_APP_FILE=./logs/app.log
# LOG_ERROR_FILE=./logs/error.log

# Campos sensíveis mascarados nos logs (CSV)
# LOG_REDACT_PATHS=req.headers.authorization,req.headers.cookie,req.body.password


# -----------------------------------------------------------------------------
# Bloqueio por versão mínima do app mobile (opcional)
# -----------------------------------------------------------------------------
# Desligado por padrão: só vale se descomentar.
# Se `plataformaApp` não vier no payload, a API assume `android`.
#
# Prioridade:
#   1. versão específica do fluxo (ex.: MOBILE_MIN_VERSION_ANDROID_LOGIN)
#   2. versão geral da plataforma (ex.: MOBILE_MIN_VERSION_ANDROID)
#
# Fluxos suportados:
#   - LOGIN       → POST /auth/login
#   - OPEN_TURNO  → POST /turno/abrir
#
# MOBILE_MIN_VERSION_ANDROID=1.8.0
# MOBILE_MIN_VERSION_ANDROID_LOGIN=1.8.0
# MOBILE_MIN_VERSION_ANDROID_OPEN_TURNO=1.8.0
# MOBILE_MIN_VERSION_IOS=1.8.0
# MOBILE_MIN_VERSION_IOS_LOGIN=1.8.0
# MOBILE_MIN_VERSION_IOS_OPEN_TURNO=1.8.0


# -----------------------------------------------------------------------------
# Uploads / fotos / APK mobile
# -----------------------------------------------------------------------------

# local | s3
UPLOAD_STORAGE=local

# Pasta base dos arquivos (use caminho ABSOLUTO em produção)
UPLOAD_ROOT=./uploads

# Pastas legadas para leitura (CSV ou JSON array) — fallback de arquivos antigos
# UPLOAD_LEGACY_ROOTS=/var/www/nexa-oper/uploads,/opt/legacy/uploads

# Base pública das URLs retornadas pela API (vazio = relativo /uploads/...)
# Ex.: https://api.seudominio.com/uploads
UPLOAD_BASE_URL=

# Tamanho máximo por arquivo (bytes) — padrão 10 MB
UPLOAD_MAX_FILE_SIZE_BYTES=10485760

# Proxy do Next.js para /uploads/* (dev: API local)
UPLOAD_PROXY_TARGET=http://localhost:3001


# -----------------------------------------------------------------------------
# Jobs internos da API
# -----------------------------------------------------------------------------

# Reconciliação de fotos de checklist (job agendado)
CHECKLIST_PHOTO_RECONCILE_ENABLED=false
CHECKLIST_PHOTO_RECONCILE_INTERVAL_MS=300000
CHECKLIST_PHOTO_RECONCILE_STARTUP_DELAY_MS=45000
CHECKLIST_PHOTO_RECONCILE_LOCK_TTL_MS=240000
CHECKLIST_PHOTO_RECONCILE_MAX_FILES=200
CHECKLIST_PHOTO_RECONCILE_MAX_RESPONSES=500
# CHECKLIST_PHOTO_RECONCILE_SCAN_ROOTS=/var/www/nexa-oper/uploads

# Fila de checklists na abertura de turno (retry assíncrono)
TURNO_CHECKLIST_SYNC_ENABLED=true
TURNO_CHECKLIST_SYNC_CRON=*/1 * * * *
TURNO_CHECKLIST_SYNC_LOCK_TTL_MS=120000

# Reconciliação escala vs turnos realizados (opcional)
# TURNO_RECONCILE_ENABLED=false
# TURNO_RECONCILE_CRON=0 2 * * *
# TURNO_RECONCILE_LOCK_TTL_MS=600000


# -----------------------------------------------------------------------------
# Storage S3 / MinIO / R2 (quando UPLOAD_STORAGE=s3)
# -----------------------------------------------------------------------------
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_ENDPOINT=
# AWS_S3_PUBLIC_URL=


# -----------------------------------------------------------------------------
# Web — Next.js + NextAuth
# -----------------------------------------------------------------------------

# URL pública do dashboard (sem barra no final)
NEXTAUTH_URL=http://localhost:3000

# Secret do NextAuth — use valor diferente do JWT_SECRET
NEXTAUTH_SECRET="troque-por-outro-secret-longo-e-aleatorio"

# Alternativa aceita pelo NextAuth
# AUTH_SECRET=

# Debug do NextAuth (somente dev)
# NEXTAUTH_DEBUG=true


# -----------------------------------------------------------------------------
# Web — variáveis públicas (expostas ao browser)
# -----------------------------------------------------------------------------

# URL pública da API (obrigatória em produção)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Base para exibir fotos/arquivos no dashboard
NEXT_PUBLIC_PHOTOS_BASE_URL=http://localhost:3001

# Base explícita de uploads/CDN (opcional; tem prioridade sobre PHOTOS_BASE_URL)
# NEXT_PUBLIC_UPLOAD_BASE_URL=https://api.seudominio.com/uploads

# Endpoint opcional para envio de logs do browser para a API
# NEXT_PUBLIC_API_LOG_URL=https://api.seudominio.com
