# =============================================================================
# NEXA OPER — Prisma / migrations
# =============================================================================
#
# Usado pelos scripts em packages/db (migrate, generate, seed, studio).
# O carregador também lê .env da raiz do monorepo, se existir.
#
# Como preparar:
#   cp packages/db/.env.example packages/db/.env
#
# Em produção, normalmente basta o DATABASE_URL correto antes de:
#   npm run db:generate
#   npm run db:migrate:deploy
#
# =============================================================================

DATABASE_URL="mysql://usuario:senha@localhost:3306/nexa_oper"

# Apenas para `prisma migrate dev` em ambiente local
# SHADOW_DATABASE_URL="mysql://usuario:senha@localhost:3306/nexa_oper_shadow"
