model User {
  id       Int    @id @default(autoincrement())
  nome     String @db.VarChar(255)
  email    String @unique @db.VarChar(255)
  username String @unique @db.VarChar(255)
  password String @db.VarChar(255)

  permissionProfileId Int?
  permissionProfile   PermissionProfile? @relation(fields: [permissionProfileId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  createdBy String    @db.VarChar(255)
  updatedAt DateTime? @updatedAt
  updatedBy String?   @db.VarChar(255)
  deletedAt DateTime?
  deletedBy String?   @db.VarChar(255)

  Session  Session[]
  Account  Account[]
  RoleUser RoleUser[]
  UserPermissionGrant UserPermissionGrant[]

  @@index([username])
  @@index([email])
  @@index([permissionProfileId], map: "idx_user_permission_profile")
}

model Account {
  id                String  @id @default(uuid())
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("contas")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  expires      DateTime

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessoes")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("tokens_verificacao")
}

model Role {
  id   Int    @id @default(autoincrement())
  nome String @db.VarChar(255)

  createdAt DateTime  @default(now())
  createdBy String    @db.VarChar(255)
  updatedAt DateTime? @updatedAt
  updatedBy String?   @db.VarChar(255)

  RoleUser RoleUser[]
}

model RoleUser {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  roleId Int
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

model UserPermissionGrant {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  permission String @db.VarChar(100)

  createdAt DateTime  @default(now())
  createdBy String    @db.VarChar(255)
  updatedAt DateTime? @updatedAt
  updatedBy String?   @db.VarChar(255)

  @@unique([userId, permission], map: "uk_user_permission_grant")
  @@index([userId], map: "idx_user_permission_grant_user")
  @@index([permission], map: "idx_user_permission_grant_permission")
}

model PermissionProfile {
  id        Int     @id @default(autoincrement())
  key       String  @unique @db.VarChar(100)
  nome      String  @db.VarChar(255)
  descricao String? @db.VarChar(500)
  ativo     Boolean @default(true)

  createdAt DateTime  @default(now())
  createdBy String    @db.VarChar(255)
  updatedAt DateTime? @updatedAt
  updatedBy String?   @db.VarChar(255)

  users                  User[]
  PermissionProfileGrant PermissionProfileGrant[]

  @@index([ativo], map: "idx_permission_profile_ativo")
}

model PermissionProfileGrant {
  id Int @id @default(autoincrement())

  profileId Int
  profile   PermissionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  permission String @db.VarChar(100)

  createdAt DateTime  @default(now())
  createdBy String    @db.VarChar(255)
  updatedAt DateTime? @updatedAt
  updatedBy String?   @db.VarChar(255)

  @@unique([profileId, permission], map: "uk_permission_profile_grant")
  @@index([profileId], map: "idx_permission_profile_grant_profile")
  @@index([permission], map: "idx_permission_profile_grant_permission")
}
